# npm configuration

# Use exact versions for consistency
save-exact=false

# Prevent automatic saving of npm-shrinkwrap.json
save=true

# Set package-lock behavior
package-lock=true

# Set registry
registry=https://registry.npmjs.org/

# Configure npm audit
audit=true

# Configure npm fund
fund=true

# Legacy peer dependencies for compatibility
legacy-peer-deps=true

# Prefer offline for faster installs (once packages are cached)
# prefer-offline=true

# Strict SSL is recommended for security
strict-ssl=true
